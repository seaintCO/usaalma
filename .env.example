# Public Supabase browser/server URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Required for encrypted connector token storage.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL used to build OAuth callback URLs.
# Local: http://localhost:3000
# Preview/Production: https://your-domain.example
NEXT_PUBLIC_APP_URL=

# Encryption key used for OAuth state signing and encrypted token storage.
APP_ENCRYPTION_KEY=

# Google OAuth client for Gmail sending.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra app credentials for Outlook sending.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenAI text model used for low-latency bilingual correction/translation.
ALMA_TRANSLATION_MODEL=

# OpenAI Realtime, transcription, and speech model configuration.
OPENAI_API_KEY=
ALMA_REALTIME_MODEL=
ALMA_REALTIME_PREMIUM_MODEL=
ALMA_REALTIME_TRANSLATION_MODEL=
ALMA_TRANSCRIPTION_MODEL=
ALMA_SPEECH_MODEL=
