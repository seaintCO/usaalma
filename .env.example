# Public Supabase browser/server URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Required for encrypted connector token storage.
# Also required for durable chat queue ownership transitions, Builder workers,
# artifact handoff, and provider webhook ingestion. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL used to build OAuth callback URLs.
# Local: http://localhost:3000
# Preview/Production: https://your-domain.example
NEXT_PUBLIC_APP_URL=

# Encryption key used for OAuth state signing and encrypted token storage.
APP_ENCRYPTION_KEY=

# Google OAuth client for Gmail sending.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra app credentials for Outlook sending.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenAI text model used for provider-backed bilingual correction/translation.
# Missing provider configuration returns a structured failure; ALMA does not use
# fake dictionary translation as successful output.
ALMA_TRANSLATION_MODEL=

# Optional canonical ALMA model routing names. These are server-read model names,
# not provider secrets.
ALMA_FAST_MODEL=
ALMA_TEXT_MODEL=
ALMA_REASONING_MODEL=
ALMA_DEEP_MODEL=
ALMA_ROUTER_MODEL=
ALMA_IMAGE_MODEL=

# OpenAI Realtime, transcription, and speech model configuration.
# Server routes read OPENAI_API_KEY at request time. Restart Next.js after
# editing .env.local so the server process sees the updated values.
OPENAI_API_KEY=
ALMA_REALTIME_MODEL=
ALMA_REALTIME_PREMIUM_MODEL=
ALMA_REALTIME_TRANSLATION_MODEL=
ALMA_TRANSCRIPTION_MODEL=
ALMA_SPEECH_MODEL=

# Meta WhatsApp Business Platform / Embedded Signup.
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=

# Optional comma-separated preview hosts that Builder may render in an iframe.
# This is an allowlist only; it does not configure a Builder Engine provider.
ALMA_BUILDER_PREVIEW_HOSTS=

# ALMA Builder Engine 1.
# Vercel control plane: queues jobs only. Do not run long-lived Builder worker
# or Gateway processes inside Next.js request handlers.
ALMA_BUILDER_ENGINE_ENABLED=true
ALMA_BUILDER_WORKER_SECRET=
ALMA_BUILDER_PREVIEW_HOSTS=

# Builder Gateway service only: holds the permanent OPENAI_API_KEY from above
# and exposes /healthz, /readyz, and POST /v1/responses.
ALMA_BUILDER_GATEWAY_URL=
ALMA_BUILDER_GATEWAY_PORT=8787
ALMA_BUILDER_GATEWAY_SIGNING_KEY=
ALMA_BUILDER_GATEWAY_AUDIENCE=
ALMA_BUILDER_CODEX_MODEL=

# Builder Worker service only: claims durable jobs and talks to E2B.
ALMA_BUILDER_E2B_TEMPLATE=alma-builder-node-lts
ALMA_BUILDER_CODEX_WORKER_ISOLATED=true
ALMA_BUILDER_WORKER_POLL_MS=5000
ALMA_BUILDER_WORKER_HEALTH_PORT=8797
ALMA_BUILDER_KEEP_PREVIEW_SANDBOX=false
E2B_API_KEY=

# Opt-in live readiness checks. Never set these in production.
ALMA_BUILDER_LIVE_E2B_CONFIRM=
ALMA_BUILDER_LIVE_E2E_CONFIRM=
ALMA_BUILDER_E2E_USER_ID=
ALMA_BUILDER_E2E_WORKSPACE_ID=

# GitHub App connector for approval-gated Builder source control.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=
