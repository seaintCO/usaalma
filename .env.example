# Public Supabase browser/server URL and anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Required for encrypted connector token storage.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL used to build OAuth callback URLs.
# Local: http://localhost:3000
# Preview/Production: https://your-domain.example
NEXT_PUBLIC_APP_URL=

# Encryption key used for OAuth state signing and encrypted token storage.
APP_ENCRYPTION_KEY=

# Google OAuth client for Gmail sending.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra app credentials for Outlook sending.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenAI text model used for provider-backed bilingual correction/translation.
# Missing provider configuration returns a structured failure; ALMA does not use
# fake dictionary translation as successful output.
ALMA_TRANSLATION_MODEL=

# OpenAI Realtime, transcription, and speech model configuration.
# Server routes read OPENAI_API_KEY at request time. Restart Next.js after
# editing .env.local so the server process sees the updated values.
OPENAI_API_KEY=
ALMA_REALTIME_MODEL=
ALMA_REALTIME_PREMIUM_MODEL=
ALMA_REALTIME_TRANSLATION_MODEL=
ALMA_TRANSCRIPTION_MODEL=
ALMA_SPEECH_MODEL=

# Meta WhatsApp Business Platform / Embedded Signup.
META_APP_ID=
META_APP_SECRET=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=

# Optional comma-separated preview hosts that Builder may render in an iframe.
# This is an allowlist only; it does not configure a Builder Engine provider.
ALMA_BUILDER_PREVIEW_HOSTS=
